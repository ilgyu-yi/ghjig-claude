#!/usr/bin/env bash
set -euo pipefail

CLAUDE_ENG_SHELL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
export CLAUDE_ENG_SHELL_ROOT

# --version short-circuit (Issue #123 / Directive #122): runs before the
# registry/scope guard so it works from any cwd, and before `exec claude`
# so it returns the shell's VERSION rather than the underlying CLI's.
# Fallback: git describe; on both-fail, diagnostic to stderr + exit 1.
if [ "${1:-}" = "--version" ]; then
  if [ -s "$CLAUDE_ENG_SHELL_ROOT/VERSION" ]; then
    cat "$CLAUDE_ENG_SHELL_ROOT/VERSION"
    exit 0
  fi
  if v=$(git -C "$CLAUDE_ENG_SHELL_ROOT" describe --tags --always 2>/dev/null) && [ -n "$v" ]; then
    printf '%s\n' "$v"
    exit 0
  fi
  printf 'claude-eng: VERSION file missing/empty and git describe unavailable\n' >&2
  exit 1
fi

# If the first arg is a directory, check if it's registered; offer to register if not.
if [ $# -gt 0 ] && [ -d "$1" ]; then
  target_path=$(cd "$1" && pwd -P)
  # Per-project registry (#316): this launcher runs BEFORE the Claude session, so
  # CLAUDE_PROJECT_DIR is unset — discover via the explicit-arg resolver against
  # target_path ("does <dir> carry its own eng-state/registry.txt?"). Source hookrt
  # for the resolver (the self-located CLAUDE_ENG_SHELL_ROOT always carries it).
  . "$CLAUDE_ENG_SHELL_ROOT/.claude/hooks/hookrt.sh"
  registry=$(eng_registry_file "$target_path")
  # Back-compat (#316): accept the per-project registry OR the legacy shared one
  # (a target registered before #316 lives only in the shared registry). New
  # registrations still write per-project via register.sh.
  legacy="$CLAUDE_ENG_SHELL_ROOT/.claude/state/registry.txt"
  registered=0
  for reg in "$registry" "$legacy"; do
    [ -f "$reg" ] || continue
    while IFS= read -r entry; do
      [ -z "$entry" ] && continue
      case "$target_path/" in
        "$entry"/*) registered=1; break ;;
      esac
      [ "$target_path" = "$entry" ] && { registered=1; break; }
    done < "$reg"
    [ "$registered" = 1 ] && break
  done
  if [ "$registered" = 0 ]; then
    printf "? '%s' is not registered. Register as workspace/%s and enter? [Y/n] " \
      "$target_path" "$(basename "$target_path")"
    read -r resp || resp="Y"
    case "${resp:-Y}" in
      [Yy]|"")
        "$CLAUDE_ENG_SHELL_ROOT/scripts/register.sh" "$target_path"
        ;;
      *)
        echo "Cancelled."
        exit 0
        ;;
    esac
  fi
  cd "$target_path"
  shift
fi

exec claude "$@"
