#!/usr/bin/env bash
# .githooks/pre-commit — local-tier adapter (SPEC §6.7). Blocks a direct commit
# to a protected branch and a staged secret by SOURCING and CALLING the shared
# helpers — it copies NO check logic (single-source invariant, §9).
# shellcheck source=/dev/null
. "$(dirname "${BASH_SOURCE[0]}")/_lib.sh"

githook_source branch_guard.sh branch || exit 0
githook_source secret_scan.sh  secret || exit 0

# 1) Direct commit to a protected branch (main/master/release/*).
_gh_branch="$(current_branch)"
if is_protected_branch "$_gh_branch"; then
  githook_block branch "pre-commit: direct commit to protected branch '${_gh_branch:-HEAD}' is blocked (SPEC §6.7). Commit on a feature branch and open a PR."
  exit 1
fi

# 2) Staged secret (scan_staged_secrets reads git diff --cached).
if ! scan_staged_secrets; then
  githook_block secret "pre-commit: a possible secret in the staged diff was detected — commit blocked (SPEC §6.7). Remove it, or allow-list the path in .shellsecretignore."
  exit 1
fi

exit 0
